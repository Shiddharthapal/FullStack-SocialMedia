---
import App from "../components/App";
import Layout from "../layouts/Layout.astro";
export const prerender = true;

export function getStaticPaths() {
  return [
    { params: { index: undefined } },
    { params: { index: "login" } },
    { params: { index: "register" } },
  ];
}

const { index } = Astro.params;
const title =
  index === "login"
    ? "Login - Fullstack developer amplify"
    : index === "register"
      ? "Register - Fullstack developer amplify"
      : "Fullstack developer amplify";

---

<Layout title={title}>
	  <App client:only="react" />
</Layout>
